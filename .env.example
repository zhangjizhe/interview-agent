# ============================================
# AI 面试智能体 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# ============================================
# LLM Providers
# ============================================

# 通义千问（OpenAI 兼容协议）
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
# P0-3 修复：qwen plus 上限 128K（保守值）
QWEN_MAX_TOKENS=128000

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
# P0-3 修复：deepseek 上限 64K
DEEPSEEK_MAX_TOKENS=64000

# P0-3 修复：provider 兜底值
LLM_DEFAULT_MAX_TOKENS=32000

# ============================================
# 博查搜索（Agent 联网搜索用）
# ============================================
BOCHA_API_KEY=your_bocha_api_key_here
BOCHA_BASE_URL=https://api.bochaai.com/v1

# ============================================
# Langfuse Cloud（可观测）
# ============================================
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# ============================================
# LangSmith（备用可观测，可选）
# ============================================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=interview-agent

# ============================================
# Infrastructure
# ============================================
DATABASE_URL=postgresql://dev:dev123@localhost:5432/interview
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
MILVUS_URL=http://localhost:19530

# ============================================
# App
# ============================================
NODE_ENV=development
PORT=3001
WEB_PORT=5173

# CORS
CORS_ORIGIN=http://localhost:5173

# Memory
MEM0_API_KEY=your_mem0_api_key_here
MEM0_HOST=
MEM0_ORG_ID=
MEM0_PROJECT_ID=

# Redis session TTL (seconds)
REDIS_SESSION_TTL=3600

# ============================================
# P0-1 修复：JWT + Rate Limiting
# ============================================
# JWT Secret（生产环境必须改）
JWT_SECRET=interview-agent-dev-secret-change-in-production
# JWT 过期时间
JWT_EXPIRES_IN=7d

# Rate Limiting（每分钟请求数/IP）
THROTTLER_TTL=60
THROTTLER_LIMIT=60

# ============================================
# P1-6 修复：Langfuse 采样率（可选）
# ============================================
# trace 完整流程采样率（默认 10%）
LANGFUSE_SAMPLE_RATE_TRACE=0.1
# span 中间节点采样率（默认 50%）
LANGFUSE_SAMPLE_RATE_SPAN=0.5
# generation LLM 调用采样率（必须 100%，否则成本分析不准）
LANGFUSE_SAMPLE_RATE_GENERATION=1.0
